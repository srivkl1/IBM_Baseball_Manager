# Pick one: "watsonx" | "custom" | "mock"
LLM_PROVIDER=watsonx

# IBM watsonx.ai — fill these to use IBM Cloud foundation models.
WATSONX_APIKEY=
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=
WATSONX_MODEL_ID=ibm/granite-3-8b-instruct

# OpenAI-compatible / open-source endpoint (vLLM, Ollama, LM Studio, …).
CUSTOM_LLM_BASE_URL=http://localhost:8080/v1
CUSTOM_LLM_API_KEY=not-needed
CUSTOM_LLM_MODEL=ibm/granite-4-h-small

# Optional: ESPN private-league credentials. Leave blank for public demo mode.
ESPN_LEAGUE_ID=1907954991
ESPN_SEASON=2026
ESPN_SWID=
ESPN_S2=

# Cache directory for pybaseball / ESPN pulls (speeds up repeat loads).
DATA_CACHE_DIR=./data_cache

# Historical data window and draft target season.
DATA_START_SEASON=2000
TARGET_SEASON=2026
RECENT_HISTORY_WINDOW=3
